{
  "name": "raschpetzer-qanat-viz",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive 3D visualization of the Raschpëtzer Roman qanat (Walferdange, Luxembourg), driven by a cited Single Source of Truth.",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/bake.mjs",
    "bake": "node scripts/bake.mjs",
    "validate": "node scripts/validate.mjs",
    "sample:lidar": "node scripts/sample-lidar.mjs",
    "seed:lidar": "node scripts/sample-lidar.mjs --seed",
    "bake:lidar": "node scripts/bake-lidar.mjs",
    "build": "node scripts/build.mjs",
    "prebuild": "node scripts/validate.mjs",
    "serve": "vite preview"
  },
  "devDependencies": {
    "vite": "^5.4.11"
  }
}
